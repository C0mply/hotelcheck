<Window x:Class="HotelCheck.Modules.ReservationValidation.UI.ReservationValidationDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reservation Validation Demo"
        Height="650"
        Width="900"
        Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Reservation Validation Demo"
                       FontFamily="Segoe UI"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>
            <TextBlock Text="Validate reservation input using the Strategy-based backend module."
                       Margin="0,8,0,0"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Foreground="#475569"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="16"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="Guest ID"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"/>
                    <TextBox x:Name="GuestIdTextBox"
                             Margin="0,6,0,0"
                             Padding="10"
                             Text="1"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                    <TextBlock Text="Room ID"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"/>
                    <TextBox x:Name="RoomIdTextBox"
                             Margin="0,6,0,0"
                             Padding="10"
                             Text="101"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="Check-in Date"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"/>
                    <DatePicker x:Name="CheckInDatePicker"
                                Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                    <TextBlock Text="Check-out Date"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"/>
                    <DatePicker x:Name="CheckOutDatePicker"
                                Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                    <CheckBox x:Name="RoomExistsCheckBox"
                              Content="Room exists"
                              IsChecked="True"
                              FontFamily="Segoe UI"
                              FontSize="14"
                              Foreground="#0F172A"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                    <CheckBox x:Name="OverlapCheckBox"
                              Content="Simulate overlapping reservation"
                              IsChecked="False"
                              FontFamily="Segoe UI"
                              FontSize="14"
                              Foreground="#0F172A"/>
                </StackPanel>

                <Button Grid.Row="3"
                        Grid.Column="0"
                        Width="180"
                        Height="42"
                        Margin="0,8,0,16"
                        Padding="12,8"
                        Content="Validate Reservation"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        FontFamily="Segoe UI"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Click="ValidateButton_Click"/>

                <Border x:Name="ResultBorder"
                        Grid.Row="4"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,8,0,0"
                        Padding="16"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="Validation Result"
                                   FontFamily="Segoe UI"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"/>
                        <TextBlock x:Name="ResultTextBlock"
                                   Margin="0,8,0,0"
                                   Text="Press the button to validate a reservation."
                                   TextWrapping="Wrap"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   Foreground="#475569"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
